class BackendRegistry {
  <<singleton>>
  -_backends: Dict~str, Type~BaseBackend~~
  -_aliases: Dict~str, str~
  -_discovered: bool
  +__new__() BackendRegistry
  +discover_backends() Dict~str, Type~
  +_discover_backends() None
  +register_aliases(name: str, aliases: List~str~, overwrite: bool=False) None
  +list_all_names() Dict~str, List~str~
  +list_backend_info() List~Dict~
  +get_backend_info(name: str) Dict
  +create_backend(backend_type: str, **kwargs) BaseBackend
  +clear() None
  +__getitem__(name: str) Type~BaseBackend~
  +__setitem__(name: str, backend_class: Type~BaseBackend~) None
  +__delitem__(name: str) None
  +__contains__(name: str) bool
  +keys() KeysView~str~
  +values() ValuesView~Type~BaseBackend~~
  +items() ItemsView~str, Type~BaseBackend~~
  +__repr__() str
}

class MemorableNames {
  -adjectives: List~str~
  -scientists: List~str~
  -used_names: Set~str~
  +generate_name() str
  +generate_unique_name() str
  +generate_unique_names(count: int) List~str~
}

%% === Inheritance / relationships ===
BaseBackend <|-- InMemoryBackend
BaseBackend <|-- LocalCSVBackend
BaseBackend <|-- LocalJSONLBackend
BaseBackend <|-- GDriveBackend

%% Backend registry relationships
BackendRegistry --> BaseBackend : manages registrations
BackendRegistry o-- "1" BACKEND_REGISTRY : global instance

class BACKEND_REGISTRY {
  <<instance>>
}
BACKEND_REGISTRY ..> BackendRegistry : instanceOf

%% Utility / helper usage
InMemoryBackend --> MemorableNames : can use (example)
LocalCSVBackend ..> LocalCSVBackend : uses private _get_file_path/_save/_load
LocalJSONLBackend ..> LocalJSONLBackend : uses private serialization helpers
