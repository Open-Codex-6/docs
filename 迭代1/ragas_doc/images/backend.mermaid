classDiagram
direction LR

%% === Classes ===
class BaseBackend {
  <<abstract>>
  +load_dataset(name: str) List~Dict~
  +load_experiment(name: str) List~Dict~
  +save_dataset(name: str, data: List~Dict~, data_model: Optional~Type~) None
  +save_experiment(name: str, data: List~Dict~, data_model: Optional~Type~) None
  +list_datasets() List~str~
  +list_experiments() List~str~
}

class InMemoryBackend {
  +_datasets: Dict~str, List~Dict~~
  +_experiments: Dict~str, List~Dict~~
  +__init__()
  +load_dataset(name: str) List~Dict~
  +load_experiment(name: str) List~Dict~
  +save_dataset(name: str, data: List~Dict~, data_model: Optional~Type~) None
  +save_experiment(name: str, data: List~Dict~, data_model: Optional~Type~) None
  +list_datasets() List~str~
  +list_experiments() List~str~
}

class LocalCSVBackend {
  +root_dir: Path
  +__init__(root_dir: str)
  +load_dataset(name: str) List~Dict~
  +load_experiment(name: str) List~Dict~
  +save_dataset(name: str, data: List~Dict~, data_model: Optional~Type~) None
  +save_experiment(name: str, data: List~Dict~, data_model: Optional~Type~) None
  +list_datasets() List~str~
  +list_experiments() List~str~
  -_get_data_dir(data_type: str) Path
  -_get_file_path(data_type: str, name: str) Path
  -_load(data_type: str, name: str) List~Dict~
  -_save(data_type: str, name: str, data: List~Dict~, data_model: Optional~Type~) None
  -_list(data_type: str) List~str~
}

