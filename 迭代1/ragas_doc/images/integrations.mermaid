  +process_event(event) None
  +get_messages() List~Message~
  +_handle_text_message_start(event) None
  +_handle_text_message_content(event) None
  +_handle_text_message_end(event) None
  +_handle_tool_call_start(event) None
  +_handle_tool_call_end(event) None
}
