%% --- Integrations classes (ragas.integrations) ---

class LangfuseTrace {
  +trace: TraceWithFullDetails
  -_langfuse_client: Langfuse
  +__init__(trace: TraceWithFullDetails)
  +get_url() Optional~str~
  +filter(span_name: str) List~Observation~
}
class TraceWithFullDetails {
  +id: str
  +timestamp: datetime
  +htmlPath: str
  +latency: int
  +totalCost: float
  +observations: List~Observation~
  +scores: List~float~
  +tags: List~str~
  +public: bool
  +environment: str
}
class Observation {
  +name: str
  +... fields ...
}

class MLflowTrace {
  +trace: Trace
  +__init__(trace: Trace)
  +get_url() str
  +get_filter(span_name: str) List~Span~
}
class Span {
  +name: str
  +... fields ...
}
class Trace {
  +info
  +search_spans(name: str) List~Span~
  +... fields ...
}

class EvaluatorChain {
  +metric: Metric
  +__init__(metric: Metric, **kwargs)
  +input_keys() List~str~
  +output_keys() List~str~
  +_call(inputs) Dict
  +_acall(inputs) Dict (async)
  +evaluate_run(run, example) EvaluationResult
}
class Chain {
  <<external>>
}
class RunEvaluator {
  <<external>>
}

class OpikTracer {
  +_evaluation_run_id: Optional~str~
  +_process_start_trace(run)
  +_process_end_trace(run)
  +_persist_run(run)
}
class LangchainOpikTracer {
